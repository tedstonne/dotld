FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    git \
    jq \
    ripgrep \
    fzf \
  && rm -rf /var/lib/apt/lists/*

# Install OpenCode CLI
RUN curl -fsSL https://opencode.ai/install | bash

# Both installers place binaries outside default PATH
ENV PATH="/root/.opencode/bin:/root/.local/bin:${PATH}"

# Install dotld CLI from GitHub Release (same as a real user would)
RUN curl -fsSL https://raw.githubusercontent.com/tedstonne/dotld/main/scripts/install.sh | bash

WORKDIR /app

# Install dotld skill globally from skills.sh
RUN npx -y skills add tedstonne/dotld@dotld --global --yes

# Copy OpenCode config
COPY opencode.docker.json /root/.config/opencode/opencode.json

# Copy test script
COPY scripts/smoke-test.sh scripts/smoke-test.sh
RUN chmod +x scripts/smoke-test.sh

CMD ["scripts/smoke-test.sh"]
